{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:Europe/Berlin}",
      "USER_UID": "${localEnv:UID:1000}",
      "USER_GID": "${localEnv:GID:1000}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0",
    },
  },
  "runArgs": ["--cap-add=NET_ADMIN", "--cap-add=NET_RAW"],
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,readonly",
    "source=${localWorkspaceFolder}/.devcontainer/allowed-domains.conf,target=/usr/local/etc/allowed-domains.conf,type=bind,readonly",
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  // Enable Claude Code autopilot inside the container. The devcontainer
  // is sandboxed (firewall-restricted, bind-mounted workspace, non-root
  // user), so the container itself is the security boundary — no need
  // for per-tool permission prompts. Writes settings.local.json (gitignored)
  // only if a .claude/ directory exists and the file doesn't already exist.
  "postCreateCommand": "if [ -d /workspace/.claude ] && [ ! -f /workspace/.claude/settings.local.json ]; then printf '{\\n  \"defaultMode\": \"bypassPermissions\"\\n}\\n' > /workspace/.claude/settings.local.json; fi",
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand",
}
