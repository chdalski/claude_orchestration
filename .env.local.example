# Copy to .env.local to override authentication for behavioral tests.
# Not required if you use OAuth (claude login) — OAuth is the default.
#
# Use this file when you want to:
# - Use an API key instead of OAuth
# - Route through a proxy (e.g., Portkey, LiteLLM)
# - Use a cloud provider (Bedrock, Vertex)

# Direct API key authentication
# ANTHROPIC_API_KEY=

# Proxy configuration (uncomment both lines)
# ANTHROPIC_API_KEY=<your-proxy-key>
# ANTHROPIC_BASE_URL=https://ai-gateway.portkey.ai/v1

# Cloud provider (uncomment one)
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1
